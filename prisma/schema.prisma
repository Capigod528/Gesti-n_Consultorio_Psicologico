generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Paciente {
  id        Int      @id @default(autoincrement())
  nombre    String
  email     String   @unique
  telefono  String?
  edad      Int
  citas     Cita[]
  
  // SOFT DELETE: Para no borrar datos médicos por error
  activo    Boolean  @default(true) 
  createdAt DateTime @default(now())

  @@map("pacientes")
}

model Especialista {
  id           Int      @id @default(autoincrement())
  nombre       String
  especialidad String   // Ej: Psicoterapia, Psiquiatría
  email        String   @unique
  telefono     String?
  citas        Cita[]   // Relación: Un especialista atiende muchas citas
  
  activo       Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@map("especialistas")
}

model Cita {
  id             Int          @id @default(autoincrement())
  fecha          DateTime
  motivo         String
  notas          String?      @db.Text
  
  // ESTADOS: Para saber si el paciente vino, canceló o está pendiente
  estado         String       @default("PENDIENTE") // PENDIENTE, COMPLETADA, CANCELADA
  
  // RELACIONES
  pacienteId     Int
  paciente       Paciente     @relation(fields: [pacienteId], references: [id])
  
  especialistaId Int
  especialista   Especialista @relation(fields: [especialistaId], references: [id])

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt // Auditoría: saber cuándo se modificó la cita

  @@map("citas")
}