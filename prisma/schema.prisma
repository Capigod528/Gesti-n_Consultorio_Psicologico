// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// modelo de tabla para Pacientes
model Paciente {
  id        Int      @id @default(autoincrement())
  nombre    String
  email     String   @unique
  telefono  String?
  edad      Int
  citas     Cita[]   // Relación: Un paciente tiene muchas citas

  @@map("pacientes")
}

// modelo de tabla para Citas Médicas
model Cita {
  id          Int      @id @default(autoincrement())
  fecha       DateTime
  motivo      String
  notas       String?  @db.Text
  pacienteId  Int      // Llave foránea
  paciente    Paciente @relation(fields: [pacienteId], references: [id])

  @@map("citas")
}
